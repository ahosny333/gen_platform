# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Generator Monitoring Platform"
APP_VERSION="1.0.0"
DEBUG=true

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY="CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_IN_PRODUCTION"
ACCESS_TOKEN_EXPIRE_MINUTES=480        # 8 hours

# ─── MQTT Broker ──────────────────────────────────────────────────────────────
MQTT_BROKER_HOST= "broker.hivemq.com" # Use public broker for testing; replace with your broker's address in production
MQTT_BROKER_PORT=1883
MQTT_USERNAME=""                       # Leave empty if broker has no auth
MQTT_PASSWORD=""
MQTT_CLIENT_ID="generator_platform_backend"
MQTT_KEEPALIVE=60

# MQTT Topics (wildcards supported)
# ESP32 publishes to:  generator/{device_id}/data
# Backend publishes to: generator/{device_id}/command
MQTT_DATA_TOPIC="generator/+/data"
MQTT_COMMAND_TOPIC_TEMPLATE="generator/{device_id}/command"

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="sqlite+aiosqlite:///./generator_platform.db"

# ─── Server ───────────────────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000

# ─── CORS (comma-separated origins for frontend dev server) ───────────────────
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000"
